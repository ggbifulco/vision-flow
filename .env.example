# VLM Provider: "gemini" (default) or "groq"
VLM_PROVIDER=gemini

# Google Gemini API (default provider)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API (alternative provider)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Telegram Bot (optional, for remote alerts)
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=

# API Security
VISIONFLOW_API_KEY=your_secret_api_key
